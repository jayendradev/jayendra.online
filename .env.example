# Public URLs (optional — shown on Work page when set)
NEXT_PUBLIC_BRIEFWIRE_URL=https://thebriefwire.com
NEXT_PUBLIC_SHOPIFY_APP_URL=
NEXT_PUBLIC_AI_SEO_DEMO_URL=
NEXT_PUBLIC_CALENDLY_URL=
# LinkedIn profile URL — used in footer and JSON-LD sameAs (helps Google trust & indexing)
NEXT_PUBLIC_LINKEDIN_URL=
# Optional: override local public/avatar.jpg
NEXT_PUBLIC_AVATAR_URL=

# Contact — where admin notifications are sent
CONTACT_EMAIL=contact@jayendra.online

# Email notifications (Resend preferred; Gmail SMTP used as fallback)
# Resend: https://resend.com — verify domain or use onboarding@resend.dev for testing
RESEND_API_KEY=
RESEND_FROM_EMAIL=contact@jayendra.online

# Gmail SMTP fallback (Google Account → Security → App passwords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=contact@jayendra.online
SMTP_PASS=
SMTP_FROM=contact@jayendra.online

# Auth & admin inbox (/admin, /messages)
AUTH_SECRET=change-this-to-a-long-random-string
ADMIN_EMAIL=contact@jayendra.online
ADMIN_PASSWORD=choose-a-strong-admin-password

# PostgreSQL (recommended for production)
# Put your database password in .env.local — NEVER commit .env.local to git.
#
# Option A — one line (password inside URL):
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/jayendraonline
#
# Option B — separate vars (password in POSTGRES_PASSWORD):
# POSTGRES_HOST=your-db-host.com
# POSTGRES_PORT=5432
# POSTGRES_USER=your_db_user
# POSTGRES_PASSWORD=your_db_password
# POSTGRES_DB=jayendraonline
# POSTGRES_SSL=true
#
# If DATABASE_URL or POSTGRES_* is set → PostgreSQL is used.
# If not set → local SQLite fallback at ./data/messages.db (dev only).
DATABASE_URL=
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=jayendraonline
POSTGRES_SSL=true
